<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0"/>
<title>Terminal Summary</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f0f3f8;--white:#fff;--border:#dde3ec;--border2:#c4ccd8;
  --ink:#12181f;--ink2:#3a4254;--muted:#6a7490;
  --blue:#3464af;--blue-lt:#e8eef8;--blue-mid:#9ab4d8;
  --teal:#0b7a6a;--teal-lt:#e4f3f0;
  --amber:#b55a08;--amber-lt:#fdeee0;
  --purple:#5a2d9c;
  --r:8px;
}
html,body{font-size:16px;font-family:'DM Sans',sans-serif;}
body{background:var(--bg);color:var(--ink);font-weight:500;padding-bottom:110px;}

/* TOPBAR */
.topbar{background:var(--blue);height:62px;display:flex;align-items:center;justify-content:space-between;padding:0 20px;position:sticky;top:0;z-index:60;box-shadow:0 2px 14px rgba(0,0,0,.2);}
.t-brand{display:flex;align-items:center;gap:10px;}
.t-icon{background:rgba(255,255,255,.15);border-radius:6px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;}
.t-name{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:#fff;}
.t-sub{font-size:.6rem;color:rgba(255,255,255,.5);letter-spacing:.07em;text-transform:uppercase;}
.t-right{display:flex;gap:8px;}
.btn{display:inline-flex;align-items:center;gap:6px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:700;padding:8px 16px;border-radius:5px;cursor:pointer;border:none;-webkit-tap-highlight-color:transparent;touch-action:manipulation;}
.btn-ghost{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.25);}
.btn-white{background:#fff;color:var(--blue);font-weight:700;min-height:40px;}

/* PAGE */
.page{max-width:960px;margin:0 auto;padding:20px 14px;}

/* CARDS */
.card{background:#fff;border:1px solid var(--border);border-radius:var(--r);box-shadow:0 1px 4px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.05);margin-bottom:16px;overflow:hidden;}
.card-hd{display:flex;align-items:center;gap:10px;padding:12px 18px;border-bottom:1px solid var(--border);background:var(--bg);}
.card-num{width:26px;height:26px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;color:#fff;flex-shrink:0;}
.cn-blue{background:var(--blue)}.cn-teal{background:var(--teal)}.cn-amber{background:var(--amber)}.cn-purple{background:var(--purple)}
.card-title{font-family:'Playfair Display',serif;font-size:.95rem;font-weight:700;}
.card-note{font-size:.68rem;margin-left:auto;background:var(--blue-lt);color:var(--blue);padding:2px 9px;border-radius:20px;font-weight:600;}
.card-body{padding:18px;}

/* GRIDS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px;}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:11px;}

/* FIELDS */
.fld{display:flex;flex-direction:column;gap:5px;}
.fld label{font-size:.76rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);}
.fld .hint{font-size:.68rem;color:var(--muted);margin-top:-3px;}
.iw{position:relative;}
.sfx{position:absolute;right:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.85rem;pointer-events:none;font-weight:700;}
input,select,textarea{background:var(--bg);border:1.5px solid var(--border);border-radius:5px;color:var(--ink);font-family:'DM Sans',sans-serif;font-size:1rem;font-weight:700;padding:9px 12px;outline:none;width:100%;transition:border-color .15s;}
input:focus,select:focus,textarea:focus{border-color:var(--blue);background:#fff;}
textarea{resize:vertical;min-height:68px;font-size:.93rem;}
input.auto-filled{background:#e8f5f0;border-color:#9dd4cc;color:var(--teal);}

/* COMPUTED */
.computed{background:var(--blue-lt);border:1.5px solid var(--blue-mid);border-radius:5px;padding:9px 12px;display:flex;align-items:center;gap:5px;}
.computed .big{font-size:1.3rem;font-weight:700;color:var(--blue);font-family:'Playfair Display',serif;}
.computed .unit{font-size:.82rem;color:var(--muted);font-weight:700;}

/* SUBSECTIONS */
.subsec{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:13px 15px;margin-bottom:11px;}
.subsec:last-child{margin-bottom:0}
.subsec-t{font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:11px;display:flex;align-items:center;gap:7px;}
.subsec-t::after{content:'';flex:1;height:1px;background:var(--border);}
.comp-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.comp-box{background:#fff;border:1px solid var(--border);border-radius:6px;padding:13px 14px;}
.comp-box-t{font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding-bottom:7px;margin-bottom:9px;border-bottom:2px solid var(--border);}
.cbt-blue{color:var(--blue)}.cbt-amber{color:var(--amber)}
.comp-items{display:flex;flex-direction:column;gap:9px;}

/* QUEUE */
.rule{height:1px;background:var(--border);margin:14px 0;}
.time-block{border:1px solid var(--border);border-radius:7px;padding:14px 16px;margin-bottom:12px;background:#fff;}
.tb-hd{display:flex;align-items:center;gap:9px;margin-bottom:13px;flex-wrap:wrap;}
.tb-num{background:var(--blue);color:#fff;width:23px;height:23px;border-radius:50%;font-size:.68rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.tb-lbl{font-size:.75rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--ink2);}
.tb-times{display:flex;align-items:center;gap:7px;margin-left:auto;}
.tb-times span{font-size:.65rem;font-weight:700;text-transform:uppercase;color:var(--muted);}
.tb-times input[type=time]{width:108px;font-size:.88rem;}
.sch-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
.sch-pill{display:inline-flex;align-items:center;padding:4px 11px;border-radius:4px;font-size:.7rem;font-weight:700;}
.sp-blue{background:var(--blue-lt);color:var(--blue);border:1px solid var(--blue-mid);}
.sp-teal{background:var(--teal-lt);color:var(--teal);border:1px solid #9dd4cc;}
.sp-amber{background:var(--amber-lt);color:var(--amber);border:1px solid #e8c49a;}

/* FOOTER BAR */
.footer-bar{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid var(--border);padding:11px 20px;display:flex;align-items:center;justify-content:space-between;z-index:55;box-shadow:0 -2px 10px rgba(0,0,0,.07);}
.footer-info{font-size:.76rem;color:var(--muted);}
.footer-info strong{color:var(--ink);}
.footer-actions{display:flex;gap:8px;}
.btn-vs{background:var(--blue);color:#fff;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.86rem;padding:10px 22px;border-radius:6px;border:none;cursor:pointer;display:flex;align-items:center;gap:6px;-webkit-tap-highlight-color:transparent;touch-action:manipulation;min-height:44px;}
.btn-rs{background:transparent;border:1.5px solid var(--border2);color:var(--ink2);font-family:'DM Sans',sans-serif;font-size:.78rem;font-weight:600;padding:9px 14px;border-radius:5px;cursor:pointer;-webkit-tap-highlight-color:transparent;}

/* TOAST */
#toast{position:fixed;bottom:80px;right:16px;background:var(--teal);color:#fff;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.8rem;padding:9px 16px;border-radius:6px;opacity:0;transform:translateY(8px);transition:opacity .3s,transform .3s;pointer-events:none;z-index:9000;box-shadow:0 4px 14px rgba(0,0,0,.18);}
#toast.show{opacity:1;transform:translateY(0);}

/* SUMMARY PANEL */
#SP{
  display:none;
  position:fixed;
  top:0;left:0;
  width:100%;height:100%;
  z-index:8000;
  background:#fff url("data:image/png;base64,") center center / cover no-repeat;
  overflow:hidden;
}
.sp-bar{
  background:#3464af;color:#fff;
  padding:7px 12px;
  display:flex;align-items:center;justify-content:space-between;
  flex-shrink:0;
}
.sp-title{font-family:'Playfair Display',serif;font-size:.85rem;font-weight:700;white-space:nowrap;}
.sp-meta{display:flex;gap:4px;flex-wrap:nowrap;margin-left:8px;overflow:hidden;}
.sp-chip{background:rgba(255,255,255,.2);border-radius:3px;padding:2px 7px;font-size:.58rem;font-weight:700;color:#fff;white-space:nowrap;}
.sp-btns{display:flex;gap:6px;flex-shrink:0;margin-left:8px;}
.sp-btn{font-family:'DM Sans',sans-serif;font-weight:700;font-size:.72rem;padding:5px 12px;border-radius:4px;cursor:pointer;border:none;-webkit-tap-highlight-color:transparent;touch-action:manipulation;min-height:34px;}
.sp-close{background:#fff;color:#3464af;}
.sp-img{background:rgba(255,255,255,.18);color:#fff;border:1px solid rgba(255,255,255,.35);}
.sp-print{background:rgba(255,255,255,.18);color:#fff;border:1px solid rgba(255,255,255,.35);}

/* Scaler wraps the grid and gets transform:scale applied by JS */
#SP-scaler{
  transform-origin:top left;
  display:grid;
  grid-template-columns:1fr 1fr 1fr 1fr;
  gap:5px;
  padding:5px;
  /* natural width = screen width, height auto so JS can measure it */
  width:100vw;
  box-sizing:border-box;
  background:rgba(255,255,255,0.82);
}

/* Column */
.sc{background:#fff;border:1px solid #ccd9ee;border-radius:4px;overflow:hidden;display:flex;flex-direction:column;}

/* Section heading — navy */
.sh{background:#3464af;color:#fff;padding:6px 9px;font-weight:700;font-size:.72rem;letter-spacing:.04em;text-transform:uppercase;flex-shrink:0;line-height:1.3;}

/* Sub-heading */
.ss{background:#e4edf8;color:#2a539a;padding:4px 9px;font-weight:700;font-size:.64rem;letter-spacing:.04em;text-transform:uppercase;border-top:1px solid #ccd8ee;flex-shrink:0;line-height:1.3;}

/* Slot heading */
.sl{background:#4a76be;color:#fff;padding:5px 9px;font-weight:700;font-size:.67rem;letter-spacing:.02em;border-top:1px solid #3a60a0;flex-shrink:0;line-height:1.3;}

/* Data row */
.sr{display:flex;align-items:baseline;border-bottom:1px solid #edf1f8;padding:4px 9px;flex-shrink:0;}
.sr:nth-child(even){background:#f6f9fd;}
.sr.kpi{background:#ecf2fb!important;}
.sr .lb{flex:0 0 50%;font-size:.58rem;font-weight:600;color:#6a7490;text-transform:uppercase;letter-spacing:.01em;padding-right:5px;line-height:1.3;}
.sr .vl{flex:1;font-weight:700;font-size:.78rem;color:#12181f;line-height:1.3;}
.sr.kpi .vl{color:#3464af;font-size:.82rem;}

/* Remarks */
.rmk{padding:4px 9px;font-size:.6rem;color:#3a4254;line-height:1.4;flex-shrink:0;}

/* RESPONSIVE */
@media(max-width:600px){
  .g4{grid-template-columns:1fr 1fr;}
  .g3{grid-template-columns:1fr 1fr;}
  .comp-grid{grid-template-columns:1fr;}
  .topbar,.footer-bar{padding-left:12px;padding-right:12px;}
}
@media(max-width:400px){
  .g2,.g3,.g4,.comp-grid{grid-template-columns:1fr;}
}
@media print{
  body>*:not(#SP){display:none!important;}
  #SP{display:block!important;position:static!important;overflow:visible!important;background:#fff!important;}
  .sp-bar{display:none!important;}
  #SP-scaler{
    transform:none!important;
    width:100%!important;
    padding:4mm!important;
    gap:3mm!important;
    background:#fff!important;
  }
  .sh,.ss,.sl,.sr.kpi,.sc{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  @page{size:landscape;margin:0;}
}
</style>
</head>
<body>

<header class="topbar">
  <div class="t-brand">
    <div class="t-icon">✈</div>
    <div><div class="t-name">Terminal Summary</div><div class="t-sub">Airport Operations Report</div></div>
  </div>
  <div class="t-right">
    <button class="btn btn-ghost" onclick="resetForm()">↺ Reset</button>
    <button class="btn btn-white" onclick="showSummary()">👁 View Summary</button>
  </div>
</header>

<div class="page">

<!-- CARD 1 -->
<div class="card">
  <div class="card-hd"><div class="card-num cn-blue">1</div><div class="card-title">Terminal Information</div></div>
  <div class="card-body">
    <div class="g4" style="margin-bottom:16px;">
      <div class="fld"><label>Terminal</label><select id="s_terminal"><option value="">— Select —</option><option>T1</option><option>T2</option><option>T3</option><option>T1 &amp; T2</option><option>All Terminals</option></select></div>
      <div class="fld"><label>Date</label><input type="date" id="s_date"/></div>
      <div class="fld">
        <label>FB % <span style="font-size:.6rem;color:var(--teal);font-weight:600;text-transform:none;">(Auto: FB Comp ÷ Dom. Arrivals × 100)</span></label>
        <div class="computed" id="fb_out" style="background:#e4f3f0;border-color:#9dd4cc;"><span class="big" style="color:var(--teal);">-</span><span class="unit">%</span></div>
      </div>
      <div class="fld">
        <label>LB % <span style="font-size:.6rem;color:var(--teal);font-weight:600;text-transform:none;">(Auto: LB Comp ÷ Dom. Arrivals × 100)</span></label>
        <div class="computed" id="lb_out" style="background:#e4f3f0;border-color:#9dd4cc;"><span class="big" style="color:var(--teal);">-</span><span class="unit">%</span></div>
      </div>
    </div>
    <div class="subsec">
      <div class="subsec-t">Total Domestic Arrival</div>
      <div class="fld" style="max-width:260px;margin-bottom:14px;"><label>Total Domestic Arrival</label><input type="number" id="da_total" min="0" placeholder="Enter total" oninput="calcFBLB()"/></div>
      <div class="comp-grid">
        <div class="comp-box">
          <div class="comp-box-t cbt-blue">FB — First Bag</div>
          <div class="comp-items">
            <div class="fld"><label>FB Compliance</label><input type="number" id="da_fb_comp" min="0" placeholder="0" oninput="calcFBLB()"/></div>
            <div class="fld"><label>FB Non Compliance</label><input type="number" id="da_fb_nc" min="0" placeholder="0"/></div>
            <div class="fld"><label>Out of Non-Compliance</label><input type="number" id="da_fb_onc" min="0" placeholder="0"/></div>
            <div class="fld"><label>ATR Non Comp</label><input type="number" id="da_fb_atr" min="0" placeholder="0"/></div>
            <div class="fld"><label>T2 FB Non Compliance</label><input type="number" id="da_t2_fb" min="0" placeholder="0"/></div>
            <div class="fld"><label>T1 FB Non Compliance</label><input type="number" id="da_t1_fb" min="0" placeholder="0"/></div>
          </div>
        </div>
        <div class="comp-box">
          <div class="comp-box-t cbt-amber">LB — Last Bag</div>
          <div class="comp-items">
            <div class="fld"><label>LB Compliance</label><input type="number" id="da_lb_comp" min="0" placeholder="0" oninput="calcFBLB()"/></div>
            <div class="fld"><label>LB Non-Compliance</label><input type="number" id="da_lb_nc" min="0" placeholder="0"/></div>
            <div class="fld"><label>Out of Non-Compliance</label><input type="number" id="da_lb_onc" min="0" placeholder="0"/></div>
            <div class="fld"><label>T2 LB Non Compliance</label><input type="number" id="da_t2_lb" min="0" placeholder="0"/></div>
            <div class="fld"><label>ATR LB Non Compliance</label><input type="number" id="da_lb_atr" min="0" placeholder="0"/></div>
            <div class="fld"><label>T1 LB Non Compliance</label><input type="number" id="da_t1_lb" min="0" placeholder="0"/></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- CARD 2 -->
<div class="card">
  <div class="card-hd"><div class="card-num cn-teal">2</div><div class="card-title">SBD — Self Bag Drop</div><div class="card-note">(Input ÷ 7,600) × 100</div></div>
  <div class="card-body">
    <div class="g2" style="max-width:500px;align-items:end;">
      <div class="fld"><label>SBD Count</label><div class="hint">Denominator: 7,600</div><input type="number" id="sbd_in" min="0" placeholder="Enter count" oninput="calcSBD()"/></div>
      <div class="fld"><label>SBD %</label><div class="computed" id="sbd_out"><span class="big">—</span><span class="unit">%</span></div></div>
    </div>
  </div>
</div>

<!-- CARD 3 -->
<div class="card">
  <div class="card-hd"><div class="card-num cn-amber">3</div><div class="card-title">Digi Yatra</div><div class="card-note">(Enrollment ÷ Dep Pax) × 100</div></div>
  <div class="card-body">
    <div class="g2" style="margin-bottom:13px;">
      <div class="subsec"><div class="subsec-t">T1</div>
        <div class="g2"><div class="fld"><label>DY Enrollment T1</label><input type="number" id="dy_e1" min="0" placeholder="0" oninput="calcDY()"/></div><div class="fld"><label>T1 Dep Passengers</label><input type="number" id="dy_d1" min="0" placeholder="0" oninput="calcDY()"/></div></div>
        <div class="fld" style="margin-top:10px;"><label>T1 DY %</label><div class="computed" id="dy_p1"><span class="big">—</span><span class="unit">%</span></div></div>
      </div>
      <div class="subsec"><div class="subsec-t">T2</div>
        <div class="g2"><div class="fld"><label>DY Enrollment T2</label><input type="number" id="dy_e2" min="0" placeholder="0" oninput="calcDY()"/></div><div class="fld"><label>T2 Dep Passengers</label><input type="number" id="dy_d2" min="0" placeholder="0" oninput="calcDY()"/></div></div>
        <div class="fld" style="margin-top:10px;"><label>T2 DY %</label><div class="computed" id="dy_p2"><span class="big">—</span><span class="unit">%</span></div></div>
      </div>
    </div>
    <div class="subsec" style="background:var(--teal-lt);border-color:#9dd4cc;">
      <div class="subsec-t" style="color:var(--teal);">Total (Auto T1+T2)</div>
      <div class="g3">
        <div class="fld"><label>Total DY Enrollment</label><input type="number" id="dy_et" placeholder="Auto" class="auto-filled" readonly/></div>
        <div class="fld"><label>Total Dep Passengers</label><input type="number" id="dy_dt" placeholder="Auto" class="auto-filled" readonly/></div>
        <div class="fld"><label>Total DY %</label><div class="computed" id="dy_pt"><span class="big">—</span><span class="unit">%</span></div></div>
      </div>
    </div>
  </div>
</div>

<!-- CARD 4 -->
<div class="card">
  <div class="card-hd"><div class="card-num cn-purple">4</div><div class="card-title">Queue Wait Time</div></div>
  <div class="card-body">
    <div class="sch-row">
      <div class="sch-pill sp-blue">📋 SCH-H</div>
      <div class="sch-pill sp-teal">✅ ECO &lt; 20 min</div>
      <div class="sch-pill sp-amber">🔒 Security &lt; 5 min</div>
    </div>
    <div class="time-block">
      <div class="tb-hd"><div class="tb-num">1</div><div class="tb-lbl">Slot 1</div><div class="tb-times"><span>From</span><input type="time" id="t1f" value="06:00"/><span>To</span><input type="time" id="t1t" value="07:00"/></div></div>
      <div class="g3">
        <div class="fld"><label>Book Load</label><input type="number" id="t1_bl" min="0" placeholder="Number"/></div>
        <div class="fld"><label>CIC (min)</label><input type="number" id="t1_cic" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>CIC Processing (min)</label><input type="number" id="t1_cicp" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>SBD Processing</label><div style="display:flex;gap:6px;"><input type="number" id="t1_sbdpm" min="0" placeholder="min" style="width:50%"/><input type="number" id="t1_sbdps" min="0" max="59" placeholder="sec" style="width:50%"/></div></div>
        <div class="fld"><label>SBD Queue Time (min)</label><input type="number" id="t1_sbd" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>Security (min)</label><input type="number" id="t1_sec" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>Entry Gate (min)</label><input type="number" id="t1_eg" min="0" step="0.1" placeholder="min"/></div>
      </div>
    </div>
    <div class="time-block">
      <div class="tb-hd"><div class="tb-num">2</div><div class="tb-lbl">Slot 2</div><div class="tb-times"><span>From</span><input type="time" id="t2f" value="10:00"/><span>To</span><input type="time" id="t2t" value="11:00"/></div></div>
      <div class="g3">
        <div class="fld"><label>Book Load</label><input type="number" id="t2_bl" min="0" placeholder="Number"/></div>
        <div class="fld"><label>CIC (min)</label><input type="number" id="t2_cic" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>CIC Processing (min)</label><input type="number" id="t2_cicp" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>SBD Processing</label><div style="display:flex;gap:6px;"><input type="number" id="t2_sbdpm" min="0" placeholder="min" style="width:50%"/><input type="number" id="t2_sbdps" min="0" max="59" placeholder="sec" style="width:50%"/></div></div>
        <div class="fld"><label>SBD Queue Time (min)</label><input type="number" id="t2_sbd" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>Security (min)</label><input type="number" id="t2_sec" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>Entry Gate (min)</label><input type="number" id="t2_eg" min="0" step="0.1" placeholder="min"/></div>
      </div>
    </div>
    <div class="time-block">
      <div class="tb-hd"><div class="tb-num">3</div><div class="tb-lbl">Slot 3</div><div class="tb-times"><span>From</span><input type="time" id="t3f" value="20:00"/><span>To</span><input type="time" id="t3t" value="21:00"/></div></div>
      <div class="g3">
        <div class="fld"><label>Book Load</label><input type="number" id="t3_bl" min="0" placeholder="Number"/></div>
        <div class="fld"><label>CIC (min)</label><input type="number" id="t3_cic" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>CIC Processing (min)</label><input type="number" id="t3_cicp" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>SBD Processing</label><div style="display:flex;gap:6px;"><input type="number" id="t3_sbdpm" min="0" placeholder="min" style="width:50%"/><input type="number" id="t3_sbdps" min="0" max="59" placeholder="sec" style="width:50%"/></div></div>
        <div class="fld"><label>SBD Queue Time (min)</label><input type="number" id="t3_sbd" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>Security (min)</label><input type="number" id="t3_sec" min="0" step="0.1" placeholder="min"/></div>
        <div class="fld"><label>Entry Gate (min)</label><input type="number" id="t3_eg" min="0" step="0.1" placeholder="min"/></div>
      </div>
    </div>
    <div class="rule"></div>
    <div class="g2">
      <div class="fld"><label>Transfer Pax (D2D)</label><input type="number" id="transfer" min="0" placeholder="Number"/></div>
      <div class="fld"><label>Others / Remarks</label><textarea id="others" placeholder="Notes…"></textarea></div>
    </div>
  </div>
</div>

</div><!-- /page -->

<div class="footer-bar">
  <div class="footer-info" id="fi">Fill in the form to begin</div>
  <div class="footer-actions">
    <button class="btn-rs" onclick="resetForm()">↺ Reset</button>
    <button class="btn-vs" onclick="showSummary()">👁 View Summary</button>
  </div>
</div>

<div id="toast">✓ Summary Ready!</div>

<!-- SUMMARY PANEL -->
<div id="SP" style="display:flex;flex-direction:column;">
  <div class="sp-bar">
    <div style="display:flex;align-items:center;flex:1;min-width:0;overflow:hidden;">
      <span class="sp-title">✈ Terminal Summary</span>
      <div class="sp-meta" id="SP-meta"></div>
    </div>
    <div class="sp-btns">
      <button class="sp-btn sp-print" onclick="window.print()">🖨 Print / Save PDF</button>
      <button class="sp-btn sp-img" onclick="downloadAsImage()">📷 Download as Image</button>
      <button class="sp-btn sp-close" onclick="closeSummary()">✕ Close</button>
    </div>
  </div>
  <div style="flex:1;overflow:hidden;position:relative;" id="SP-wrap">
    <div id="SP-scaler"></div>
  </div>
</div>

<script>
// ── helpers ──────────────────────────────────────────────
function gid(id){ return document.getElementById(id); }
function val(id){ var el=gid(id); return el?el.value:''; }
function num(id){ return parseFloat(val(id))||0; }

function clamp100(el){
  var n=parseFloat(el.value);
  if(n>100)el.value=100;
  if(n<0)el.value=0;
}

// ── calculations ─────────────────────────────────────────
function fmtPct(v){
  // Remove unnecessary trailing zeros: 100.00->100, 85.50->85.5, 12.34->12.34
  return parseFloat(v.toFixed(2)).toString();
}

function setPct(id,n,d){
  var el=gid(id);
  if(!d){ el.innerHTML='<span class="big">-</span><span class="unit"></span>'; return '-'; }
  var v=fmtPct((n/d)*100);
  el.innerHTML='<span class="big">'+v+'</span><span class="unit"> %</span>';
  return v;
}

function calcFBLB(){
  var total = num('da_total');
  var fbEl  = gid('fb_out');
  var lbEl  = gid('lb_out');
  if(!total){
    fbEl.innerHTML='<span class="big" style="color:var(--teal);">-</span><span class="unit">%</span>';
    lbEl.innerHTML='<span class="big" style="color:var(--teal);">-</span><span class="unit">%</span>';
    updateFooter(); return;
  }
  var fbComp = num('da_fb_comp');
  var lbComp = num('da_lb_comp');
  var fbPct  = fbComp ? fmtPct((fbComp/total)*100) : '-';
  var lbPct  = lbComp ? fmtPct((lbComp/total)*100) : '-';
  fbEl.innerHTML='<span class="big" style="color:var(--teal);">'+(fbPct==='-'?'-':fbPct)+'</span><span class="unit">'+(fbPct==='-'?'':' %')+'</span>';
  lbEl.innerHTML='<span class="big" style="color:var(--teal);">'+(lbPct==='-'?'-':lbPct)+'</span><span class="unit">'+(lbPct==='-'?'':' %')+'</span>';
  updateFooter();
}

function calcSBD(){
  var inp=num('sbd_in'), el=gid('sbd_out');
  if(!inp){ el.innerHTML='<span class="big">-</span><span class="unit"></span>'; updateFooter(); return; }
  var v=fmtPct((inp/7600)*100);
  el.innerHTML='<span class="big">'+v+'</span><span class="unit"> %</span>';
  updateFooter();
}

function calcDY(){
  var e1=num('dy_e1'),d1=num('dy_d1'),e2=num('dy_e2'),d2=num('dy_d2');
  var et=e1+e2, dt=d1+d2;
  gid('dy_et').value=et||'';
  gid('dy_dt').value=dt||'';
  setPct('dy_p1',e1,d1);
  setPct('dy_p2',e2,d2);
  setPct('dy_pt',et,dt);
  updateFooter();
}

function updateFooter(){
  var term=val('s_terminal')||'-';
  var date=val('s_date');
  var dStr=date?new Date(date).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}):'-';
  var sbdEl=gid('sbd_out').querySelector('.big').textContent;
  var fbEl =gid('fb_out').querySelector('.big').textContent;
  var lbEl =gid('lb_out').querySelector('.big').textContent;
  gid('fi').innerHTML='Terminal: <strong>'+term+'</strong> &nbsp;&middot;&nbsp; Date: <strong>'+dStr+'</strong> &nbsp;&middot;&nbsp; FB: <strong>'+(fbEl==='-'?'-':fbEl+'%')+'</strong> &nbsp;&middot;&nbsp; LB: <strong>'+(lbEl==='-'?'-':lbEl+'%')+'</strong>';
}

// ── reset ────────────────────────────────────────────────
function resetForm(){
  var inputs=document.querySelectorAll('input:not([type=time]),select,textarea');
  for(var i=0;i<inputs.length;i++){
    if(inputs[i].tagName==='SELECT') inputs[i].selectedIndex=0;
    else inputs[i].value='';
  }
  gid('t1f').value='06:00'; gid('t1t').value='07:00';
  gid('t2f').value='10:00'; gid('t2t').value='11:00';
  gid('t3f').value='20:00'; gid('t3t').value='21:00';
  gid('s_date').value=new Date().toISOString().split('T')[0];
  gid('sbd_out').innerHTML='<span class="big">-</span><span class="unit">%</span>';
  gid('fb_out').innerHTML='<span class="big" style="color:var(--teal);">-</span><span class="unit">%</span>';
  gid('lb_out').innerHTML='<span class="big" style="color:var(--teal);">-</span><span class="unit">%</span>';
  gid('dy_p1').innerHTML='<span class="big">-</span><span class="unit">%</span>';
  gid('dy_p2').innerHTML='<span class="big">-</span><span class="unit">%</span>';
  gid('dy_pt').innerHTML='<span class="big">-</span><span class="unit">%</span>';
  updateFooter();
}

// listen for any input change
var allInputs=document.querySelectorAll('input,select,textarea');
for(var i=0;i<allInputs.length;i++){
  allInputs[i].addEventListener('input',updateFooter);
}

// ── summary ──────────────────────────────────────────────
function showSummary(){
  var terminal = val('s_terminal')||'-';
  var dateStr  = val('s_date');
  var fmtDate  = dateStr ? new Date(dateStr).toLocaleDateString('en-GB',{day:'2-digit',month:'long',year:'numeric'}) : '-';
  var genDate  = new Date().toLocaleString('en-GB',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});
  var sbdBig   = gid('sbd_out').querySelector('.big').textContent;
  var fbPct    = gid('fb_out').querySelector('.big').textContent;
  var lbPct    = gid('lb_out').querySelector('.big').textContent;
  var dy1      = gid('dy_p1').querySelector('.big').textContent;
  var dy2v     = gid('dy_p2').querySelector('.big').textContent;
  var dyt      = gid('dy_pt').querySelector('.big').textContent;

  // meta chips in top bar
  gid('SP-meta').innerHTML=
    '<span class="sp-chip">'+terminal+'</span>'+
    '<span class="sp-chip">'+fmtDate+'</span>'+
    '<span class="sp-chip">FB: '+(fbPct!=='-'?fbPct+'%':'-')+'</span>'+
    '<span class="sp-chip">LB: '+(lbPct!=='-'?lbPct+'%':'-')+'</span>'+
    '<span class="sp-chip">'+genDate+'</span>';

  function SH(t){ return '<div class="sh">'+t+'</div>'; }
  function SS(t){ return '<div class="ss">'+t+'</div>'; }
  function SL(t){ return '<div class="sl">'+t+'</div>'; }
  function SR(lb,vl,kpi){
    return '<div class="sr'+(kpi?' kpi':'')+'"><div class="lb">'+lb+'</div><div class="vl">'+(vl||'-')+'</div></div>';
  }
  function COL(html){ return '<div class="sc">'+html+'</div>'; }

  var slots=[
    {n:'1',from:val('t1f'),to:val('t1t'),bl:val('t1_bl'),cic:val('t1_cic'),cicp:val('t1_cicp'),sbdpm:val('t1_sbdpm'),sbdps:val('t1_sbdps'),sbd:val('t1_sbd'),sec:val('t1_sec'),eg:val('t1_eg')},
    {n:'2',from:val('t2f'),to:val('t2t'),bl:val('t2_bl'),cic:val('t2_cic'),cicp:val('t2_cicp'),sbdpm:val('t2_sbdpm'),sbdps:val('t2_sbdps'),sbd:val('t2_sbd'),sec:val('t2_sec'),eg:val('t2_eg')},
    {n:'3',from:val('t3f'),to:val('t3t'),bl:val('t3_bl'),cic:val('t3_cic'),cicp:val('t3_cicp'),sbdpm:val('t3_sbdpm'),sbdps:val('t3_sbdps'),sbd:val('t3_sbd'),sec:val('t3_sec'),eg:val('t3_eg')},
  ];

  function slotHTML(s){
    var sp=(s.sbdpm?s.sbdpm+'m ':'')+( s.sbdps?s.sbdps+'s':'')||'-';
    return SL('Slot '+s.n+' &nbsp; '+(s.from||'--')+' &ndash; '+(s.to||'--'))
      +SR('Book Load',s.bl||'-')+SR('CIC (min)',s.cic?s.cic+' min':'-')
      +SR('CIC Processing',s.cicp?s.cicp+' min':'-')+SR('SBD Processing',sp)
      +SR('SBD Queue Time',s.sbd?s.sbd+' min':'-')+SR('Security',s.sec?s.sec+' min':'-')
      +SR('Entry Gate',s.eg?s.eg+' min':'-');
  }

  // COL 0: Terminal Info + FB + LB
  var c0=SH('1. Terminal Info');
  c0+=SR('Terminal',terminal)+SR('Date',fmtDate)+SR('Total Dom. Arrival',val('da_total'));
  c0+=SR('FB %',fbPct!=='-'?fbPct+'%':'-',true)+SR('LB %',lbPct!=='-'?lbPct+'%':'-',true);
  c0+=SS('FB &mdash; First Bag');
  c0+=SR('FB Compliance',val('da_fb_comp'))+SR('FB Non-Comp',val('da_fb_nc'));
  c0+=SR('Out of Non-Comp',val('da_fb_onc'))+SR('ATR Non-Comp',val('da_fb_atr'));
  c0+=SR('T2 FB Non-Comp',val('da_t2_fb'))+SR('T1 FB Non-Comp',val('da_t1_fb'));
  c0+=SS('LB &mdash; Last Bag');
  c0+=SR('LB Compliance',val('da_lb_comp'))+SR('LB Non-Comp',val('da_lb_nc'));
  c0+=SR('Out of Non-Comp',val('da_lb_onc'))+SR('T2 LB Non-Comp',val('da_t2_lb'));
  c0+=SR('ATR LB Non-Comp',val('da_lb_atr'))+SR('T1 LB Non-Comp',val('da_t1_lb'));

  // COL 1: SBD + Digi Yatra
  var c1=SH('2. SBD &mdash; Self Bag Drop');
  c1+=SR('SBD Count',val('sbd_in'))+SR('Denominator','7,600');
  c1+=SR('SBD %',sbdBig==='-'?'-':sbdBig+'%',true);
  c1+=SH('3. Digi Yatra');
  c1+=SS('T1')+SR('DY Enrollment T1',val('dy_e1'))+SR('T1 Dep Pax',val('dy_d1'))+SR('T1 DY %',dy1==='-'?'-':dy1+'%',true);
  c1+=SS('T2')+SR('DY Enrollment T2',val('dy_e2'))+SR('T2 Dep Pax',val('dy_d2'))+SR('T2 DY %',dy2v==='-'?'-':dy2v+'%',true);
  c1+=SS('Total (T1+T2)')+SR('Total DY Enrollment',val('dy_et'))+SR('Total Dep Pax',val('dy_dt'))+SR('Total DY %',dyt==='-'?'-':dyt+'%',true);

  // COL 2: Queue header + Slot 1 + Slot 2
  var c2=SH('4. Queue Wait Time &nbsp;&middot;&nbsp; SCH-H');
  c2+=slotHTML(slots[0])+slotHTML(slots[1]);

  // COL 3: Slot 3 + Transfer + Remarks
  var c3=SH('Queue (cont.)');
  c3+=slotHTML(slots[2]);
  c3+=SS('Transfer &amp; Remarks');
  c3+=SR('Transfer Pax (D2D)',val('transfer')||'-');
  var oth=val('others');
  if(oth.trim()) c3+='<div class="rmk"><strong style="display:block;font-size:.6rem;letter-spacing:.05em;text-transform:uppercase;color:#6a7490;margin-bottom:2px;">Remarks</strong>'+oth.replace(/\n/g,'<br/>')+'</div>';

  // Inject into scaler
  var scaler = gid('SP-scaler');
  scaler.innerHTML = COL(c0)+COL(c1)+COL(c2)+COL(c3);
  scaler.style.transform = 'none';

  // Show panel
  var sp = gid('SP');
  sp.style.display = 'flex';

  // After render, scale to fill the available area
  setTimeout(function(){
    var wrap = gid('SP-wrap');
    var avW  = wrap.offsetWidth  || window.innerWidth;
    var avH  = wrap.offsetHeight || (window.innerHeight - 44);
    var natW = scaler.scrollWidth;
    var natH = scaler.scrollHeight;
    if(natW > 0 && natH > 0){
      var scale = Math.min(avW / natW, avH / natH);
      scaler.style.transformOrigin = 'top left';
      scaler.style.transform = 'scale('+scale+')';
      scaler.style.width = natW+'px';
      scaler.style.height = natH+'px';
    }
  }, 60);

  var t=gid('toast');
  t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); },2000);
}
function closeSummary(){
  gid('SP').style.display='none';
}

function downloadAsImage(){
  var scaler = gid('SP-scaler');
  var terminal = val('s_terminal')||'Terminal';
  var dateStr  = val('s_date');
  var fileName = 'TerminalSummary'+(dateStr?'_'+dateStr:'')+'.png';

  // Temporarily reset transform so html2canvas captures full content
  var prevTransform = scaler.style.transform;
  var prevWidth     = scaler.style.width;
  var prevHeight    = scaler.style.height;
  scaler.style.transform = 'none';
  scaler.style.width  = 'auto';
  scaler.style.height = 'auto';

  html2canvas(scaler, {
    scale: 2,
    useCORS: true,
    backgroundColor: '#f0f3f8',
    logging: false
  }).then(function(canvas){
    // Restore transform
    scaler.style.transform = prevTransform;
    scaler.style.width     = prevWidth;
    scaler.style.height    = prevHeight;

    var link = document.createElement('a');
    link.download = fileName;
    link.href = canvas.toDataURL('image/png');
    link.click();
  }).catch(function(){
    scaler.style.transform = prevTransform;
    scaler.style.width     = prevWidth;
    scaler.style.height    = prevHeight;
    alert('Image download failed. Try Print / Save PDF instead.');
  });
}

// init
gid('s_date').value=new Date().toISOString().split('T')[0];
updateFooter();
</script>
</body>
</html>
